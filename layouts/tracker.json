		]
	},

	"tracker_default": 
	{
		"type": "container",
		"content": 
		{
			"type": "dock",
			"dropshadow": true,
			"content": [
			{
				"type": "dock",
				"dock": "left",
				"h_alignment": "stretch",
				"margin": "0,0,3,0",
				"content": [
				{
					"type": "group",
					"header": "Items",
					"dock": "top",
