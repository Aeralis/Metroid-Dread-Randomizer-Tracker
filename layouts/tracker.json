{
	"difficulty_settings":
	{
		"type": "tabbed",
		"tabs": [
		{
			"title": "Start Location",
			"content": 
			{
				"type": "array",
				"orientation": "veritcal",
				"content": [
				{
					"type": "item",
					"h_alignment": "center",
