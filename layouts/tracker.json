						"type": "button_popup",
						"style": "settings",
						"layout": "difficulty_settings"
					},
					"content": [
					{
						"type": "array",
						"margin": "0,0",
						"orientation": "horizontal",
						"content": [
						{
							"type": "layout",
							"key": "interactive_devices"
						},
						{
							"type": "layout",
							"key": "items_and_bosses"
						}
						]
					},
					]
				},
				{
					"type": "array",
					"margin": "0,0",
					"content": [
					{
						"type": "layout",
						"key": "consumables"
					},
					{
						"type": "group",
						"header": "Pinned Locations",
						"dock": "bottom",
						"content": [
						{
							"type": "recentpins",
							"style": "wrap",
							"h_alignment": "left",
							"orientation": "vertical",
							"compact": true
						}
						]
					}
					]
				}
				]
			},
